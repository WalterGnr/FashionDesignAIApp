# Copy this file to .env when implementation begins.
# Never commit real secrets.

# Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Database
POSTGRES_DB=fashion_app
POSTGRES_USER=fashion_app
POSTGRES_PASSWORD=fashion_app_local
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://fashion_app:fashion_app_local@127.0.0.1:5432/fashion_app

# Redis, planned for later background jobs
REDIS_URL=redis://localhost:6379/0

# OpenAI
# Real API keys must stay on the backend side and must never be exposed in Electron renderer code.
OPENAI_API_KEY=

# Object storage, planned for renders and exports
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
