# Copy this file to .env when implementation begins.
# Never commit real secrets.

# Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Database
POSTGRES_DB=fashion_app
POSTGRES_USER=fashion_app
POSTGRES_PASSWORD=fashion_app_local
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://fashion_app:fashion_app_local@127.0.0.1:5432/fashion_app

# Redis and background render jobs
REDIS_URL=redis://localhost:6379/0
RENDER_DISPATCH_ENABLED=true
RENDER_PROVIDER=mock
RENDER_STORAGE_ROOT=.data/render-assets
RENDER_MAX_ASSET_BYTES=26214400
TECH_PACK_STORAGE_ROOT=.data/tech-pack-assets
TECH_PACK_MAX_ASSET_BYTES=52428800

# OpenAI
# Real API keys must stay on the backend side and must never be exposed in Electron renderer code.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# Future cloud object storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
